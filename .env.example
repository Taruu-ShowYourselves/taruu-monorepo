# Sync App Environment Variables
# Copy this file to .env.local and fill in the values

# ============================================
# Clerk Authentication
# https://clerk.com
# ============================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ============================================
# Qubik Blockchain
# https://qubik.io
# ============================================
QUBIK_API_KEY=qubik_...
QUBIK_NETWORK=testnet # or mainnet

# ============================================
# Converge Database
# https://converge.io
# ============================================
CONVERGE_API_KEY=conv_...
CONVERGE_PROJECT_ID=proj_...

# ============================================
# Green Invoice (Payments)
# https://greeninvoice.co.il
# ============================================
GREEN_INVOICE_API_KEY=gi_...
GREEN_INVOICE_SECRET=gi_secret_...

# ============================================
# Grow (Payment Management)
# https://grow.io
# ============================================
GROW_API_KEY=grow_...

# ============================================
# Resend (Email)
# https://resend.com
# ============================================
RESEND_API_KEY=re_...

# ============================================
# Application
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
