# Sync App Environment Variables
# Copy this file to .env.local and fill in the values

# ============================================
# Supabase Database
# https://supabase.com
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# WARNING: Service role key should ONLY be used server-side, never expose to client
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ============================================
# JWT Session Secret
# Generate with: openssl rand -hex 32
# ============================================
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRY=7d

# ============================================
# Google OAuth (Primary Auth)
# https://console.cloud.google.com
# ============================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ============================================
# Facebook OAuth (Social Proof)
# https://developers.facebook.com
# ============================================
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# ============================================
# Instagram OAuth (Social Proof)
# https://developers.facebook.com
# ============================================
INSTAGRAM_APP_ID=your_instagram_app_id
INSTAGRAM_APP_SECRET=your_instagram_app_secret

# ============================================
# Green Invoice (Payments)
# https://greeninvoice.co.il
# ============================================
GREEN_INVOICE_API_KEY=your_green_invoice_api_key
GREEN_INVOICE_SECRET=your_green_invoice_webhook_secret

# ============================================
# Qubik Blockchain (Token Minting)
# https://qubik.io
# ============================================
QUBIK_API_KEY=your_qubik_api_key
QUBIK_NETWORK=testnet

# ============================================
# Resend (Email)
# https://resend.com
# ============================================
RESEND_API_KEY=your_resend_api_key

# ============================================
# Application
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000