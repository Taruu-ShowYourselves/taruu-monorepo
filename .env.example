# Taru App Environment Variables
# Copy this file to .env.local and fill in the values

# ============================================
# Supabase (Database + Auth)
# https://supabase.com/dashboard
# All OAuth providers (Google, Facebook, Instagram) are configured
# in Supabase Dashboard → Authentication → Providers
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ============================================
# Paddle (Payments — Merchant of Record)
# https://www.paddle.com  /  https://developer.paddle.com
# Sandbox dashboard: https://sandbox-vendors.paddle.com
# ============================================
# 'sandbox' or 'production' — selects sandbox-api.paddle.com vs api.paddle.com
PADDLE_ENV=sandbox
# Server-side API key (Paddle > Developer Tools > Authentication)
PADDLE_API_KEY=your_paddle_api_key
# Webhook signing secret (Paddle > Developer Tools > Notifications > destination)
PADDLE_WEBHOOK_SECRET=your_paddle_webhook_secret
# Catalog Price IDs (pri_...) for the two billable actions
PADDLE_PRICE_VOTE_PARTICIPATION=pri_your_vote_participation_price
PADDLE_PRICE_VOTE_CREATION=pri_your_vote_creation_price
# Client-side token for Paddle.js (optional — overlay/inline checkout)
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=your_paddle_client_token

# ============================================
# Green Invoice / morning (Merch store — Israeli MoR + invoicing)
# https://www.morning.co.il  /  https://greeninvoice.docs.apiary.io
# ============================================
# 'sandbox' or 'production' — selects sandbox.d.greeninvoice.co.il vs api.greeninvoice.co.il
GREENINVOICE_ENV=sandbox
# API key id + secret (morning > Settings > API)
GREENINVOICE_API_KEY_ID=your_greeninvoice_api_key_id
GREENINVOICE_API_SECRET=your_greeninvoice_api_secret
# Optional payment plugin/terminal id from the account
GREENINVOICE_PLUGIN_ID=
# Shared secret guarding the paid-notification webhook. Set a long random value
# in production — the checkout appends it to the notify URL (?token=...) and the
# webhook rejects any POST that doesn't carry it. Unset = endpoint runs OPEN (dev).
GREENINVOICE_WEBHOOK_SECRET=

# ============================================
# Qubik Blockchain (Token Minting)
# https://qubik.io
# ============================================
QUBIK_API_KEY=your_qubik_api_key
QUBIK_NETWORK=testnet

# ============================================
# Resend (Email)
# https://resend.com
# ============================================
RESEND_API_KEY=your_resend_api_key

# ============================================
# Expo Push Notifications
# https://expo.dev
# ============================================
EXPO_ACCESS_TOKEN=your_expo_access_token

# ============================================
# Google OAuth (Identity Score: 40 points)
# https://console.cloud.google.com/apis/credentials
# ============================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id

# ============================================
# Facebook OAuth (Identity Score: 20 points)
# https://developers.facebook.com/apps
# ============================================
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
EXPO_PUBLIC_FACEBOOK_APP_ID=your_facebook_app_id

# ============================================
# Instagram OAuth (Identity Score: 20 points)
# https://developers.facebook.com/apps (Instagram Basic Display)
# ============================================
INSTAGRAM_APP_ID=your_instagram_app_id
INSTAGRAM_APP_SECRET=your_instagram_app_secret
EXPO_PUBLIC_INSTAGRAM_APP_ID=your_instagram_app_id

# ============================================
# JWT Session Management
# ============================================
JWT_SECRET=generate_random_32_byte_hex_string
JWT_EXPIRY=7d

# ============================================
# Beehiiv Newsletter
# https://www.beehiiv.com
# ============================================
BEEHIIV_API_KEY=your_beehiiv_api_key
BEEHIIV_PUBLICATION_ID=your_beehiiv_publication_id

# ============================================
# Cron Job Security
# Used for authenticating cron endpoint calls
# ============================================
CRON_SECRET=generate_random_secret_for_cron_auth

# ============================================
# Bags.fm SocialFi Integration
# https://docs.bags.fm / https://dev.bags.fm (API keys)
# ============================================
BAGS_API_KEY=your_bags_api_key
# Also reused as the compressed-NFT minter keypair (base58 or JSON byte array).
BAGS_MASTER_WALLET_PRIVATE_KEY=base64_encoded_solana_private_key
BAGS_MASTER_WALLET_ADDRESS=your_solana_wallet_address
BAGS_WEBHOOK_SECRET=your_bags_webhook_secret

# ============================================
# Solana compressed-NFT certificates (Metaplex Bubblegum + Helius + Pinata)
# Minter keypair = BAGS_MASTER_WALLET_PRIVATE_KEY above. All three required to
# mint; otherwise certificate records stay pending (no spend).
# ============================================
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_key
SOLANA_MERKLE_TREE=your_bubblegum_merkle_tree_address
PINATA_JWT=your_pinata_jwt
# Optional override for the metadata image base (defaults to the app's cert art).
NFT_IMAGE_CDN_URL=https://taruu.co.il/images/certificates

# ============================================
# Upstash Redis (Rate Limiting)
# https://console.upstash.com
# Required for production rate limiting persistence
# ============================================
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# ============================================
# Phone OTP — SMS delivery
# Codes are generated, hashed, and verified in-app on Cloudflare Workers KV
# (binding OTP_KV in apps/web/wrangler.jsonc). This is only the SMS transport:
# point it at any modern SMS REST API. Unset → mock-degrade (dev soft-pass).
# ============================================
SMS_API_URL=
SMS_API_KEY=
SMS_FROM=

# ============================================
# Application URLs
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
EXPO_PUBLIC_API_URL=http://localhost:3000
