{
  "name": "sync-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Sync - Civic consensus platform for Israeli municipalities",
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@sync/web",
    "dev:mobile": "turbo dev --filter=@sync/mobile",
    "build": "turbo build",
    "build:web": "turbo build --filter=@sync/web",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.4.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
